# Arquivo MCP Server Configuration
# Copy this file to .env and adjust values as needed

# Rate limit for outgoing requests to Arquivo.pt (requests per second)
MAX_REQUESTS_PER_SECOND=1

# Number of retry attempts on transient network errors
MAX_RETRIES=4

# Base timeout in milliseconds (adaptive: max(base, 30s + maxItems*600ms), clamped 30-180s)
TIMEOUT_MS=120000

# Log level: debug, info, warn, error
LOG_LEVEL=info
