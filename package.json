{
  "name": "arquivo-mcp",
  "version": "0.1.0",
  "description": "MCP server for Arquivo.pt — access Portuguese web archive from LLMs",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "arquivo-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http --port=3000",
    "dev": "tsx --watch src/index.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "test": "vitest run --exclude tests/integration",
    "test:integration": "INTEGRATION=true vitest run tests/integration",
    "check": "make check"
  },
  "keywords": [
    "mcp",
    "arquivo.pt",
    "web-archive",
    "model-context-protocol"
  ],
  "author": "Rodolfo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rodolfo/arquivo-mcp"
  },
  "bugs": {
    "url": "https://github.com/rodolfo/arquivo-mcp/issues"
  },
  "homepage": "https://github.com/rodolfo/arquivo-mcp#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": ">=1.0.0 <1.28.0",
    "cheerio": "^1.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.0.0"
  }
}
